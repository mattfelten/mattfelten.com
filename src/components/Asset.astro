---
import { Picture } from 'astro:assets';
import cx from 'clsx';

import Placeholder from './Placeholder.astro';

const {
	alt = '',
	autoplay = true,
	caption,
	className,
	controls = false,
	expand,
	href,
	src,
	fullWidth,
	...props
} = Astro.props;

const classes = cx(
	'Assets rounded-lg bg-accent',
	fullWidth && 'Assets--full-width',
	className,
);
---

<style>
	a {
		display: block;
		transition: all 0.1s ease-in-out;

		&:hover,
		&:focus-visible {
			transform: scale(1.06);
			box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
		}
	}

	img {
		border-style: none;
		display: block;
		height: auto;
		max-width: 100%;
		width: 100%;
		margin: 0;
	}

	video {
		display: block;
		height: auto;
		max-width: 100%;
		width: 100%;
	}

	small {
		display: block;
		margin-top: 1em;

		* {
			margin: 0;
		}
	}
</style>

<div class="asset-wrap">
	{
		src ? (
			() => {
				const isExtension = (ext: string) => {
					if (typeof src === 'string')
						return src.endsWith(ext);
					return src.src.endsWith(ext);
				};
				const getLink = () => {
					if (href) return href;
					if (expand) {
						if (typeof src === 'string') return src;
						if (typeof src.src === 'string')
							return src.src;
						return false;
					}
					return false;
				};

				const getAssetContent = () => {
					if (
						isExtension('mov') ||
						isExtension('mp4') ||
						isExtension('webm')
					)
						return (
							<video
								src={src}
								autoplay={autoplay}
								controls={controls}
								class={classes}
								{...props}
							>
								{alt}
							</video>
						);

					if (isExtension('gif') || isExtension('svg'))
						return (
							<img
								src={
									typeof src === 'string'
										? src
										: src.src
								}
								alt={alt}
								class={classes}
								{...props}
							/>
						);

					return (
						<Picture
							src={src}
							alt={alt}
							class={classes}
							{...props}
						/>
					);
				};

				if (getLink())
					return (
						<a href={getLink()}>{getAssetContent()}</a>
					);
				return getAssetContent();
			}
		) : (
			<Placeholder />
		)
	}

	{caption && <small set:html={caption} />}
</div>
