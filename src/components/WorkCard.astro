---
import { Image } from 'astro:assets';

const { entry, hero } = Astro.props;
const { cover, coverAlt, title, intro } = entry.data;
---

<a href={`/work/${entry.id}`} class="group block">
	{cover && coverAlt && (
		<div class:list={[
			"bg-accent/80 group-hover:bg-accent aspect-video overflow-hidden rounded-lg shadow-2xl transition-colors",
			hero && "mt-4",
		]}>
			<Image
				src={cover}
				alt={coverAlt}
				class="h-full w-full object-cover"
			/>
		</div>
	)}
	<p class:list={[
		hero ? "line-length-lg mt-4" : "mt-3 text-base",
	]}>
		<span class:list={[
			"decoration-accent text-strong font-medium underline decoration-2 underline-offset-4 group-hover:decoration-3",
			hero && "whitespace-nowrap",
		]}>
			{title}
		</span>
		{' — '}
		<span>{intro}</span>
	</p>
</a>
