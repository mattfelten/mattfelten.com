---
interface Props {
	title: string;
	description: string;
	isbn?: string;
	url?: string;
}

const { title, description, isbn, url } = Astro.props;
const linkUrl = url ?? (isbn ? `https://amazon.com/dp/${isbn}` : undefined);
const coverUrl = isbn
	? `https://covers.openlibrary.org/b/isbn/${isbn}-L.jpg`
	: '/book-placeholder.svg';
---

<a href={linkUrl} target="_blank" rel="noopener noreferrer" class="group block">
	<div class="mb-3 flex h-52 items-end transition-transform duration-200 group-hover:-translate-y-1">
		<img
			src={coverUrl}
			alt={title}
			loading="lazy"
			class="w-full rounded"
			style="max-height: 100%; object-fit: contain; object-position: bottom; box-shadow: 4px 6px 16px rgba(0,0,0,0.25), 2px 3px 6px rgba(0,0,0,0.15);"
		/>
	</div>
	<h3 class="text-strong text-sm font-medium leading-snug">{title}</h3>
	<p class="text-subdued mt-1 text-xs leading-snug">{description}</p>
</a>
