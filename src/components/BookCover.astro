---
interface Props {
	title: string;
	author: string;
	description: string;
	isbn: string;
	url: string;
}

const { title, author, description, isbn, url } = Astro.props;
const coverUrl = `https://covers.openlibrary.org/b/isbn/${isbn}-L.jpg`;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="group block">
	<div class="mb-3 transition-transform duration-200 group-hover:-translate-y-1">
		<img
			src={coverUrl}
			alt={`${title} by ${author}`}
			loading="lazy"
			class="w-full rounded"
			style="box-shadow: 4px 6px 16px rgba(0,0,0,0.25), 2px 3px 6px rgba(0,0,0,0.15);"
		/>
	</div>
	<h3 class="text-strong text-sm font-medium leading-snug">{title}</h3>
	<p class="text-subdued mt-1 text-xs leading-snug">{description}</p>
</a>
