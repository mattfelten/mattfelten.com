---
import Placeholder from './Placeholder.astro';

const { role, src } = Astro.props;
---

<div
	class="not-prose flex flex-col gap-3 rounded-lg border border-[rgba(255,255,255,0.06)] bg-[hsl(0,0%,6%)] p-4"
>
	<div class="flex items-center gap-3">
		<div class="h-10 w-10 shrink-0 overflow-hidden rounded-full">
			{src ? <img src={src} alt="" class="h-full w-full object-cover" /> : <Placeholder />}
		</div>
		<span class="text-strong text-lg font-medium">{role}</span>
	</div>
	<ul class="text-default flex flex-col gap-1.5 text-sm leading-snug">
		<slot />
	</ul>
</div>
