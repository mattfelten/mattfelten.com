---
import cx from 'clsx';

const { title, accent, class: className, compact } = Astro.props;

const classes = cx(
	'not-prose flex flex-col gap-2 rounded-lg border',
	compact ? 'p-2' : 'p-4',
	accent
		? 'border-accent/30 bg-accent/5'
		: 'border-[rgba(255,255,255,0.06)] bg-[hsl(0,0%,6%)]',
	className,
);

const titleClasses = cx(
	'text-sm font-medium tracking-wide uppercase',
	accent ? 'text-accent' : 'text-subdued',
);
---

<div class={classes}>
	{title && <span class={titleClasses}>{title}</span>}
	<slot />
</div>
