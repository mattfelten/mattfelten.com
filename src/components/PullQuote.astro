---
import cx from 'clsx';

const { citation, className, inline, title } = Astro.props;

const classes = cx(
	'not-prose text-strong border-accent my-8 border-l-3 py-2 pl-5 text-2xl leading-snug font-light md:text-3xl [&_strong]:font-medium',
	inline && 'not-fullwidth',
	className,
);
---

<blockquote class={classes}>
	{
		title && (
			<span class="text-subdued mb-2 block text-sm font-medium tracking-wide uppercase">
				{title}
			</span>
		)
	}
	<slot />
	{
		citation && (
			<cite class="text-subdued mt-3 block text-base not-italic">
				{citation}
			</cite>
		)
	}
</blockquote>
