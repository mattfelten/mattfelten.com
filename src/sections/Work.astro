---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const work = (await getCollection('work'))
	.filter(item => item.data.featured)
	.sort((a, b) => b.data.year - a.data.year);

const [hero, ...rest] = work;
---

{
	work.length > 0 && (
		<section>
			<div class="space-y-6 text-xl">
				{hero && (
					<a href={`/work/${hero.id}`} class="group block">
						{hero.data.cover && hero.data.coverAlt && (
							<div class="bg-accent/80 group-hover:bg-accent mt-4 aspect-video overflow-hidden rounded-lg shadow-2xl transition-colors">
								<Image
									src={hero.data.cover}
									alt={hero.data.coverAlt}
									class="h-full w-full object-cover"
								/>
							</div>
						)}
						<p class="line-length-lg mt-4">
							<span class="decoration-accent text-strong font-medium whitespace-nowrap underline decoration-2 underline-offset-4 group-hover:decoration-3">
								{hero.data.title}
							</span>
							{' — '}
							<span>{hero.data.intro}</span>
						</p>
					</a>
				)}

				{rest.length > 0 && (
					<ul class="grid gap-6 sm:grid-cols-2">
						{rest.map(
							({
								data: {
									cover,
									coverAlt,
									intro,
									title,
								},
								id,
							}) => (
								<li>
									<a
										href={`/work/${id}`}
										class="group block"
									>
										{cover && coverAlt && (
											<div class="bg-accent/80 group-hover:bg-accent aspect-video overflow-hidden rounded-lg shadow-2xl transition-colors">
												<Image
													src={cover}
													alt={coverAlt}
													class="h-full w-full object-cover"
												/>
											</div>
										)}
										<p class="mt-3 text-base">
											<span class="decoration-accent text-strong font-medium underline decoration-2 underline-offset-4 group-hover:decoration-3">
												{title}
											</span>
											{' — '}
											<span>{intro}</span>
										</p>
									</a>
								</li>
							),
						)}
					</ul>
				)}
			</div>
		</section>
	)
}
