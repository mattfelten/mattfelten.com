---
// Generates redirect pages at old /posts/<date>-<title> URLs.
// Primary redirect is handled by netlify.toml; this is a dev fallback.

export async function getStaticPaths() {
	const files = import.meta.glob('/src/content/posts/**/*.{md,mdx}');
	return Object.keys(files).flatMap(path => {
		const relative = path.replace('/src/content/posts/', '');
		const withoutExt = relative.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '');
		// Only redirect date-prefixed posts; skip drafts
		if (!/^\d{4}-\d{2}-\d{2}-/.test(withoutExt)) return [];
		const newSlug = withoutExt.replace(/^\d{4}-\d{2}-\d{2}-/, '');
		return [{ params: { slug: withoutExt }, props: { newSlug } }];
	});
}

const { newSlug } = Astro.props;
const target = `/articles/${newSlug}`;
---

<html>
	<head>
		<meta http-equiv="refresh" content={`0;url=${target}`} />
		<link rel="canonical" href={target} />
	</head>
	<body>
		<a href={target}>Redirecting…</a>
	</body>
</html>
