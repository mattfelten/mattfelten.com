---
import { getCollection } from 'astro:content';

import BookCover from '@components/BookCover.astro';
import Section from '@components/Section.astro';
import Layout from '@layouts/default.astro';

const books = await getCollection('library');

const categories = [
	{
		key: 'classics',
		label: 'Classics',
		description: 'These are the ones that keep coming up. I still reference them in conversations years after reading them.',
	},
	{
		key: 'craft',
		label: 'Craft',
		description: 'The hard skills: visual design, interaction patterns, understanding what makes interfaces work.',
	},
	{
		key: 'communication',
		label: 'Communication',
		description: 'How I think about and talk about design work, both to myself and to others.',
	},
	{
		key: 'collaboration',
		label: 'Collaboration',
		description: 'How I work with teams, facilitate decisions, and get design done in the real world.',
	},
] as const;
---

<Layout title="Design Library">
	<Section title="Design Library">
		<div class="space-y-16">
			{
				categories.map(({ key, label, description }) => {
					const categoryBooks = books.filter((b) => b.data.category === key);
					if (!categoryBooks.length) return null;
					return (
						<div>
							<div class="mb-6">
								<h2 class="text-strong text-xl font-medium">{label}</h2>
								<p class="text-subdued mt-1">{description}</p>
							</div>
							<div class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4">
								{categoryBooks.map((book) => (
									<BookCover {...book.data} />
								))}
							</div>
						</div>
					);
				})
			}
		</div>
	</Section>
</Layout>
