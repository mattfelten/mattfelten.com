---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

import Prose from '@layouts/prose.astro';

export async function getStaticPaths() {
	const workEntries = await getCollection('work');
	return workEntries.map(entry => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const {
	title,
	company,
	year,
	endYear,
	active,
	cover,
	coverAlt,
	intro,
} = entry.data;
const { Content } = await render(entry);

const allWork = await getCollection('work');
const children = allWork
	.filter(w => w.data.parent === entry.id)
	.sort((a, b) => b.data.year - a.data.year);

function formatYear(
	year: number,
	endYear?: number,
	active?: boolean,
) {
	if (active) return `${year} – Present`;
	if (endYear && endYear !== year) return `${year}–${endYear}`;
	return year.toString();
}
---

<Prose title={title} className="prose-case-study max-w-[85ch]">
	<div class="not-prose not-fullwidth mb-8 flex flex-col gap-5">
		<div class="flex flex-col gap-3">
			<h1 class="text-strong mb-0! leading-tight font-medium">
				{title}
			</h1>
			{
				intro && (
					<p class="text-strong line-length-md mb-0 text-2xl leading-snug font-light md:text-3xl">
						{intro}
					</p>
				)
			}
		</div>
		<div class="flex flex-col gap-0.5">
			<span class="text-subdued text-sm font-medium"
				>{company}</span
			>
			<span class="text-subdued text-sm"
				>{formatYear(year, endYear, active)}</span
			>
		</div>
	</div>
	{
		cover && coverAlt && (
			<div class="asset-wrap bg-accent not-prose mb-8 aspect-video overflow-hidden rounded-lg shadow-2xl">
				<Image
					src={cover}
					alt={coverAlt}
					class="h-full w-full object-cover"
				/>
			</div>
		)
	}
	<Content />
	{
		children.length > 0 && (
			<>
				<hr />
				<div class="not-prose">
					<div class="mb-8 flex flex-col gap-2">
						<h2 class="text-strong text-3xl font-medium">
							Case Studies
						</h2>
						<p class="text-subdued line-length-md">
							Deeper dives into specific projects under{' '}
							{title}.
						</p>
					</div>
					<ul class="flex flex-col gap-10">
						{children.map((child, i) => (
							<li>
								<a
									href={`/work/${child.id}`}
									class="group block"
								>
									{child.data.cover &&
										child.data.coverAlt && (
											<div class="bg-accent/80 group-hover:bg-accent aspect-video overflow-hidden rounded-lg shadow-2xl transition-colors">
												<Image
													src={
														child.data
															.cover
													}
													alt={
														child.data
															.coverAlt
													}
													class="h-full w-full object-cover"
												/>
											</div>
										)}
									<div class="mt-4 flex flex-col gap-1">
										<h3 class="text-strong text-xl font-medium">
											<span class="decoration-accent underline decoration-2 underline-offset-4 group-hover:decoration-3">
												{child.data.title}
											</span>
										</h3>
										<div class="text-subdued flex flex-wrap gap-x-3 text-sm">
											{child.data.role && (
												<span>
													{child.data.role}
												</span>
											)}
											<span>
												{formatYear(
													child.data.year,
													child.data
														.endYear,
													child.data.active,
												)}
											</span>
										</div>
										<p class="text-default line-length-lg mt-2 text-lg leading-snug">
											{child.data.intro}
										</p>
									</div>
								</a>
							</li>
						))}
					</ul>
				</div>
			</>
		)
	}
</Prose>
