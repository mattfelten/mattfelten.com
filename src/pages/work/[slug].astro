---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

import CaseStudy from '@layouts/CaseStudy.astro';

export async function getStaticPaths() {
	const workEntries = await getCollection('work');
	return workEntries.map(entry => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const {
	title,
	company,
	year,
	endYear,
	active,
	cover,
	coverAlt,
	intro,
	role,
} = entry.data;
const { Content } = await render(entry);

const allWork = await getCollection('work');
const children = allWork
	.filter(w => w.data.parent === entry.id)
	.sort((a, b) => b.data.year - a.data.year);

function formatYear(
	year: number,
	endYear?: number,
	active?: boolean,
) {
	if (active) return `${year} – Present`;
	if (endYear && endYear !== year) return `${year}–${endYear}`;
	return year.toString();
}
---

<CaseStudy title={title}>
	<div class="not-prose mb-8 flex flex-col gap-5">
		<div class="flex flex-col gap-3">
			<h1 class="text-strong mb-0! leading-tight font-medium">
				{title}
			</h1>
			{
				intro && (
					<p class="text-strong line-length-md mb-0 text-2xl leading-snug font-light md:text-3xl">
						{intro}
					</p>
				)
			}
		</div>
		<div class="flex flex-col gap-0.5">
			<span class="text-subdued text-sm font-medium"
				>{company}</span
			>
			{role && <span class="text-subdued text-sm">{role}</span>}
			<span class="text-subdued text-sm"
				>{formatYear(year, endYear, active)}</span
			>
		</div>
	</div>
	{
		cover && coverAlt && (
			<div class="asset-wrap bg-accent not-prose mb-8 aspect-video overflow-hidden rounded-lg shadow-2xl">
				<Image
					src={cover}
					alt={coverAlt}
					class="h-full w-full object-cover"
				/>
			</div>
		)
	}
	<Content />
	{children.length > 0 && (
		<div class="not-prose mt-16">
			<h2 class="text-strong mb-6 text-2xl font-medium">Case Studies</h2>
			<ul class="grid gap-6 sm:grid-cols-2">
				{children.map(child => (
					<li>
						<a href={`/work/${child.id}`} class="group block">
							{child.data.cover && child.data.coverAlt && (
								<div class="bg-accent/50 group-hover:bg-accent aspect-[16/10] overflow-hidden rounded-lg shadow-lg transition-colors">
									<Image
										src={child.data.cover}
										alt={child.data.coverAlt}
										class="h-full w-full object-contain"
									/>
								</div>
							)}
							<div class="mt-3 flex flex-col gap-0.5">
								<h3 class="text-strong group-hover:text-accent font-medium transition-colors">
									{child.data.title}
								</h3>
								{child.data.role && (
									<span class="text-subdued text-sm">{child.data.role}</span>
								)}
								<span class="text-subdued text-sm">
									{formatYear(child.data.year, child.data.endYear, child.data.active)}
								</span>
								<p class="text-subdued mt-1 text-sm leading-snug">
									{child.data.intro}
								</p>
							</div>
						</a>
					</li>
				))}
			</ul>
		</div>
	)}
</CaseStudy>
