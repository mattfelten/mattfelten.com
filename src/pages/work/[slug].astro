---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

import CaseStudy from '@layouts/CaseStudy.astro';

export async function getStaticPaths() {
	const workEntries = await getCollection('work');
	return workEntries.map(entry => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const {
	title,
	company,
	year,
	endYear,
	active,
	cover,
	coverAlt,
	intro,
	role,
} = entry.data;
const { Content } = await render(entry);

function formatYear(
	year: number,
	endYear?: number,
	active?: boolean,
) {
	if (active) return `${year} – Present`;
	if (endYear && endYear !== year) return `${year}–${endYear}`;
	return year.toString();
}
---

<CaseStudy title={title}>
	<div class="not-prose mb-8 flex flex-col gap-4">
		<h1 class="text-strong mb-0! leading-tight font-medium">
			{title}
		</h1>
		{
			intro && (
				<p class="text-strong mb-0 text-2xl leading-snug font-light md:text-3xl">
					{intro}
				</p>
			)
		}
		<div class="flex flex-col gap-0.5">
			<span class="text-subdued text-sm font-medium"
				>{company}</span
			>
			{role && <span class="text-subdued text-sm">{role}</span>}
			<span class="text-subdued text-sm"
				>{formatYear(year, endYear, active)}</span
			>
		</div>
	</div>
	{
		cover && coverAlt && (
			<div class="asset-wrap bg-accent/10 not-prose mb-8 aspect-video overflow-hidden rounded-lg shadow-sm">
				<Image
					src={cover}
					alt={coverAlt}
					class="h-full w-full object-cover"
				/>
			</div>
		)
	}
	<Content />
</CaseStudy>
