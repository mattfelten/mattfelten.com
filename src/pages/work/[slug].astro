---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

import WorkCard from '@components/WorkCard.astro';
import Prose from '@layouts/prose.astro';

export async function getStaticPaths() {
	const workEntries = await getCollection('work');
	return workEntries.map(entry => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const {
	title,
	company,
	year,
	endYear,
	active,
	cover,
	coverAlt,
	intro,
} = entry.data;
const { Content } = await render(entry);

const allWork = await getCollection('work');
const children = allWork
	.filter(w => w.data.parent === entry.id)
	.sort((a, b) => b.data.year - a.data.year);

function formatYear(
	year: number,
	endYear?: number,
	active?: boolean,
) {
	if (active) return `${year} \u2013 Present`;
	if (endYear && endYear !== year) return `${year}\u2013${endYear}`;
	return year.toString();
}
---

<Prose title={title} className="prose-case-study max-w-[85ch]">
	<div class="not-prose not-fullwidth mb-8 flex flex-col gap-5">
		<div class="flex flex-col gap-3">
			<h1 class="text-strong mb-0! leading-tight font-medium">
				{title}
			</h1>
			{
				intro && (
					<p class="text-strong line-length-md mb-0 text-2xl leading-snug font-light md:text-3xl">
						{intro}
					</p>
				)
			}
		</div>
		<div class="flex flex-col gap-0.5">
			<span class="text-subdued text-sm font-medium"
				>{company}</span
			>
			<span class="text-subdued text-sm"
				>{formatYear(year, endYear, active)}</span
			>
		</div>
	</div>
	{
		cover && coverAlt && (
			<div class="asset-wrap bg-accent not-prose mb-8 aspect-video overflow-hidden rounded-lg shadow-2xl">
				<Image
					src={cover}
					alt={coverAlt}
					class="h-full w-full object-cover"
				/>
			</div>
		)
	}
	<Content />
	{
		children.length > 0 && (
			<>
				<hr />
				<div class="not-prose not-fullwidth">
					<h2 class="text-strong mb-4 text-3xl font-medium">
						Case Studies
					</h2>
					<ul class="grid gap-6 sm:grid-cols-2">
						{children.map(child => (
							<li>
								<WorkCard entry={child} />
							</li>
						))}
					</ul>
				</div>
			</>
		)
	}
</Prose>
