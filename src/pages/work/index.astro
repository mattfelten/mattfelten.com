---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

import Section from '@components/Section.astro';
import Layout from '@layouts/default.astro';

const work = (await getCollection('work')).sort((a, b) => {
	const aYear = a.data.active
		? Infinity
		: a.data.endYear || a.data.year;
	const bYear = b.data.active
		? Infinity
		: b.data.endYear || b.data.year;
	return bYear - aYear;
});

// Group by company, preserving sort order
const grouped = work.reduce(
	(acc, item) => {
		const key = item.data.company;
		if (!acc.has(key)) {
			// Compute the company date range from its projects
			const companyItems = work.filter(
				w => w.data.company === key,
			);
			const minYear = Math.min(
				...companyItems.map(w => w.data.year),
			);
			const isActive = companyItems.some(w => w.data.active);
			const maxYear = isActive
				? undefined
				: Math.max(
						...companyItems.map(
							w => w.data.endYear || w.data.year,
						),
					);

			acc.set(key, {
				company: key,
				minYear,
				maxYear,
				isActive,
				items: [],
			});
		}
		acc.get(key)!.items.push(item);
		return acc;
	},
	new Map<
		string,
		{
			company: string;
			minYear: number;
			maxYear: number | undefined;
			isActive: boolean;
			items: typeof work;
		}
	>(),
);

function formatRange(
	minYear: number,
	maxYear: number | undefined,
	isActive: boolean,
) {
	if (isActive) return `${minYear} – Present`;
	if (maxYear && maxYear !== minYear)
		return `${minYear}–${maxYear}`;
	return minYear.toString();
}
---

<Layout title="Work">
	<Section title="Work">
		<div class="space-y-12">
			{
				[...grouped.values()].map(
					({
						company,
						minYear,
						maxYear,
						isActive,
						items,
					}) => (
						<section>
							<div class="mb-4 flex items-baseline justify-between">
								<h2 class="text-strong text-xl font-medium">
									{company}
								</h2>
								<span class="text-subdued text-sm">
									{formatRange(
										minYear,
										maxYear,
										isActive,
									)}
								</span>
							</div>
							<ul class="grid gap-6 lg:grid-cols-2">
								{items.map(
									({
										data: {
											cover,
											coverAlt,
											intro,
											title,
										},
										id,
									}) => (
										<li>
											<a
												href={`/work/${id}`}
												class="group block"
											>
												{cover &&
													coverAlt && (
														<div class="bg-accent/50 group-hover:bg-accent aspect-[16/10] overflow-hidden rounded-lg shadow-lg transition-colors">
															<Image
																src={
																	cover
																}
																alt={
																	coverAlt
																}
																class="h-full w-full object-contain"
															/>
														</div>
													)}
												<div class="mt-3 flex flex-col gap-0.5">
													<h3 class="text-strong group-hover:text-accent font-medium transition-colors">
														{title}
													</h3>
													<p class="text-subdued text-sm leading-snug">
														{intro}
													</p>
												</div>
											</a>
										</li>
									),
								)}
							</ul>
						</section>
					),
				)
			}
		</div>
	</Section>
</Layout>
