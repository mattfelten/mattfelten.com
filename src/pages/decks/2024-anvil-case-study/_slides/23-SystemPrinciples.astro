---
import { TextBlockSlide } from '@decks';

const principles = [
	{
		title: 'People First',
		body: 'We are mindful of how many people are using our tools, both directly and indirectly. We focus on making a great experience for all types of people.',
	},
	{
		title: 'Open and Transparent',
		body: 'Collaboration is our backbone. We want everyone working on products to feel included, able to participate, and that their voices are heard in evolving our tools.',
	},
	{
		title: 'Clear and Approachable',
		body: 'Provide effective and helpful support, training, and information sharing. Flexibly adjust how we communicate based on what is needed. Our tools themselves are intuitive and understandable.',
	},
	{
		title: 'Always Evolving',
		body: 'Explore new tools, workflows, and processes to continually improve our tools and the experience using them. Our tools will continue to get better over time when new information is found.',
	},
	{
		title: 'Thoughtful Details',
		body: 'We spend time understanding complex problem spaces and exploring in depth to create delightful, natural, and purpose-driven tools.',
	},
	{
		title: 'Holistic Experience',
		body: 'Our modular tools should feel seamless, familiar, and intuitive. Every piece of our system should be trusted to be carefully and deliberately considered.',
	},
];
---

<TextBlockSlide
	subtitle="System Principles"
	items={principles}
	cols={2}
	bodySize="2xl"
/>
