---
import { TextBlockSlide } from '@decks';

const principles = [
	{
		title: 'People',
		body: 'Dig in to the teams motivations, efforts, and well-being on an individual level. Understand the team.',
	},
	{
		title: 'Purpose',
		body: 'Align motivations with business needs. Share, inform, and contextualize what is happening with the company.',
	},
	{
		title: 'Process',
		body: 'Align and streamline workflows internally for efficiency. Clarify workflows and educate externally.',
	},
];
---

<TextBlockSlide
	title="Management Principles"
	items={principles}
	cols={1}
	bodySize="3xl"
	containerClass="max-w-[773px]"
/>
