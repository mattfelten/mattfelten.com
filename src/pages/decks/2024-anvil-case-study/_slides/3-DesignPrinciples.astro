---
import { TextBlockSlide } from '@decks';

const principles = [
	{
		title: 'Good Design is Invisible',
		body: 'Do the hard work so that the experience feels natural.',
	},
	{
		title: 'Open Culture',
		body: 'Everyone contributes to good design.',
	},
	{
		title: 'Flexibly Opinionated',
		body: 'Have a point of view, backed by data.<br />Be open to change.',
	},
	{
		title: 'Incrementally Correct',
		body: 'Accept that design is never done. Iterate on what good enough means.',
	},
	{
		title: 'Think Big, Work Small',
		body: 'Understand the goal. Break it down. Validate decisions and get the details right.',
	},
];
---

<TextBlockSlide
	title="Design Principles"
	items={principles}
	cols={2}
	bodySize="3xl"
/>
