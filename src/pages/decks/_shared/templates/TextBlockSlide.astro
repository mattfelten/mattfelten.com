---
// Grid of `title + body` text blocks. Configurable column count and
// body size/color. Replaces the narrower TwoColumnGridSlide.
//
// Used for principle/topic-list slides where each cell is a labeled
// chunk of explanatory text. Cells render as plain divs (not cards) —
// reach for CardGridSlide if you want the bordered/filled treatment.

import Slide from './Slide.astro';

interface Item {
	title: string;
	body: string;
}

interface Props {
	title?: string;
	subtitle?: string;
	items: Item[];
	/** Number of grid columns. Default 2. */
	cols?: 1 | 2 | 3;
	/** Body text size. Tighter for dense slides (default '2xl'). */
	bodySize?: '2xl' | '3xl';
	/** Body text color. Default 'subdued'. */
	bodyColor?: 'subdued' | 'default';
	align?: 'top' | 'center' | 'bottom';
	/** Tailwind class on the grid container (e.g. `max-w-[773px]`). */
	containerClass?: string;
}

const {
	title,
	subtitle,
	items,
	cols = 2,
	bodySize = '2xl',
	bodyColor = 'subdued',
	align,
	containerClass,
} = Astro.props;

const colsClass = {
	1: 'grid-cols-1',
	2: 'grid-cols-2',
	3: 'grid-cols-3',
}[cols];

const bodySizeClass = { '2xl': 'text-2xl', '3xl': 'text-3xl' }[bodySize];
const bodyColorClass = {
	subdued: 'text-subdued',
	default: 'text-default',
}[bodyColor];
---

<Slide title={title} subtitle={subtitle} align={align}>
	<div class:list={['grid gap-7', colsClass, containerClass]}>
		{
			items.map(item => (
				<div>
					<div class="text-strong text-4xl font-medium">
						{item.title}
					</div>
					<div
						class:list={[
							'mt-2',
							bodySizeClass,
							bodyColorClass,
						]}
						set:html={item.body}
					/>
				</div>
			))
		}
	</div>
</Slide>
