---
// A single rounded card. Title + bulleted list of items. Used by
// CardGridSlide (2x2 stats grid).

interface Props {
	title: string;
	items: string[];
}

const { title, items } = Astro.props;
---

<div
	class="rounded-[20px] border border-weak/[0.18] bg-[#111827]/60 px-4 py-3"
>
	<h3 class="m-0 mb-2 text-3xl font-medium leading-[1.1] text-strong">
		{title}
	</h3>
	<ul class="m-0 list-none p-0">
		{
			items.map(item => (
				<li class="my-[10px] text-2xl leading-[1.4] text-subdued">
					{item}
				</li>
			))
		}
	</ul>
</div>
